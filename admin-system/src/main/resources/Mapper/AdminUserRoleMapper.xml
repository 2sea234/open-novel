<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kxhy.admin.mapper.AdminUserRoleMapper">

    <delete id="deleteRolesByUserId">
        delete from admin_user_role where user_id = #{userId}
    </delete>

    <insert id="batchInsertRoles">
        insert into admin_user_role (
            user_id,
            role_id,
            create_by
        )
        values
        <foreach collection="roleIds" item="roleIds" separator=",">
            (
                #{userId},
                #{roleIds},
                #{adminId}
            )
        </foreach>
    </insert>

    <select id="selectRoleIdsByUserId" resultType="java.lang.Long">
        select role_id from admin_user_role where user_id = #{userId}
    </select>



</mapper>