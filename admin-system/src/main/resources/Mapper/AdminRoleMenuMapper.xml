<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kxhy.admin.mapper.AdminRoleMenuMapper">

    <select id="selectMenuIdsByRoleId" resultType="java.lang.Long">
        select menu_id
        from admin_role_menu
        where role_id = #{roleId}
    </select>

    <delete id="deleteMenusByRoleId">
        delete from admin_role_menu
        where role_id = #{roleId}
    </delete>

    <insert id="batchInsertRoleMenus">
        insert into admin_role_menu
        (
        role_id,
        menu_id,
        create_by,
        create_time
        )
        values
        <foreach collection="menuIds" item="menuId" separator=",">
            (
            #{roleId},
            #{menuId},
            #{adminId},
            now()
            )
        </foreach>
    </insert>

</mapper>